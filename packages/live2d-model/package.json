{
  "name": "@tina-chris/live2d-model",
  "version": "0.1.0",
  "description": "Live2D Model",
  "type": "module",
  "private": true,
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./components": {
      "types": "./dist/types/components/index.d.ts",
      "import": "./dist/components.mjs"
    },
    "./model-storage": {
      "types": "./dist/types/modelStorage/index.d.ts",
      "import": "./dist/model-storage.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "vue-tsc --noEmit",
    "build": "pnpm run build:lib && pnpm run build:types",
    "build:lib": "vite build",
    "build:types": "vue-tsc --project tsconfig.build.json"
  },
  "dependencies": {
    "@pixi/app": "^6.5.10",
    "@pixi/constants": "^6.5.10",
    "@pixi/core": "^6.5.10",
    "@pixi/display": "^6.5.10",
    "@pixi/extensions": "^6.5.10",
    "@pixi/math": "^6.5.10",
    "@pixi/runner": "^6.5.10",
    "@pixi/settings": "^6.5.10",
    "@pixi/ticker": "^6.5.10",
    "@pixi/utils": "^6.5.10",
    "@ricky0123/vad-web": "^0.0.30",
    "@vueuse/core": "catalog:",
    "onnxruntime-web": "^1.24.3",
    "pixi-live2d-display": "^0.4.0",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vue-tsc": "catalog:"
  }
}
